{
  "description": "Notion 워크스페이스 검색·쿼리 도구를 사용자 인가(ask) 게이트 뒤로 보낸다. 사용자가 지정한 페이지 밖으로 자동 탐색이 새는 것을 Cowork 툴 레벨에서 막는다.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__.*notion.*(search|query).*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/gate-notion-search.sh"
          }
        ]
      }
    ]
  }
}
